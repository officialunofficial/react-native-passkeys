{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"sortImports": {
		"groups": [
			"value-builtin",
			"value-external",
			"value-internal",
			{ "newlinesBetween": true },
			"value-parent",
			"value-sibling",
			"value-index",
			{ "newlinesBetween": true },
			"type"
		],
		"newlinesBetween": true,
		"ignoreCase": true
	}
}
